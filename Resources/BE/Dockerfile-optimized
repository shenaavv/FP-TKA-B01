FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first (for layer caching)
COPY requirements-optimized.txt .

# Install Python dependencies (including gevent)
RUN pip install --no-cache-dir -r requirements-optimized.txt

# Copy optimized application code
COPY app_optimized.py ./app.py

# Create non-root user for security
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser
USER appuser

# Expose port
EXPOSE 5000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:5000/health || exit 1

# Run Gunicorn with gevent worker
# gevent: async I/O — setiap worker handle ribuan greenlet concurrent
# worker-connections: max greenlet per worker (default 1000)
CMD ["sh", "-c", "gunicorn \
    --workers ${GUNICORN_WORKERS:-3} \
    --worker-class ${GUNICORN_WORKER_CLASS:-gevent} \
    --worker-connections ${GUNICORN_WORKER_CONNECTIONS:-1000} \
    --timeout ${GUNICORN_TIMEOUT:-120} \
    --bind 0.0.0.0:5000 \
    --access-logfile - \
    --error-logfile - \
    --log-level info \
    app:app"]
