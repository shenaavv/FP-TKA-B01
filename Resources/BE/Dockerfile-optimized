FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first (for layer caching)
COPY requirements-optimized.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements-optimized.txt

# Copy optimized application code
COPY app_optimized.py ./app.py

# Create non-root user for security
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser
USER appuser

# Expose port
EXPOSE 5000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:5000/health || exit 1

# Run Gunicorn dengan gthread worker
# gthread: thread pool per worker, kompatibel dengan pymongo 4.x
# Gevent TIDAK digunakan karena conflict dengan pymongo background threads
# 4 workers × 4 threads = 16 concurrent slots per instance
# 2 instance × 16 = 32 concurrent slots total (vs baseline: 16)
CMD ["sh", "-c", "gunicorn \
    --workers ${GUNICORN_WORKERS:-4} \
    --threads ${GUNICORN_THREADS:-4} \
    --worker-class ${GUNICORN_WORKER_CLASS:-gthread} \
    --timeout ${GUNICORN_TIMEOUT:-120} \
    --bind 0.0.0.0:5000 \
    --access-logfile - \
    --error-logfile - \
    --log-level info \
    app:app"]
