# =====================================================
# .env.multivm.example
# Template variabel environment untuk setup 3-VM
# Salin ke .env di masing-masing VM dan isi nilainya
# =====================================================

# ── MongoDB credentials (sama di semua VM) ──────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=TKAB01@2026
MONGO_INITDB_DATABASE=orderdb

# ── MongoDB URI (pakai PRIVATE IP dari VM3) ──────────
# Ganti 10.xxx.xxx.xxx dengan private IP VM3 dari DigitalOcean
MONGO_URI=mongodb://admin:TKAB01%402026@10.xxx.xxx.xxx:27017/orderdb?authSource=admin
# Catatan: @ di password harus di-encode jadi %40

# ── VM2 Private IP (dipakai oleh Nginx di VM1) ───────
# Ganti dengan private IP VM2 dari DigitalOcean VPC
# Hanya diperlukan di VM1
VM2_PRIVATE_IP=10.xxx.xxx.xxx

# ── JWT config ───────────────────────────────────────
JWT_SECRET=ganti-dengan-string-acak-panjang-minimal-32-karakter
JWT_EXPIRES=86400

# ── Gunicorn tuning (opsional, ada default di compose) ─
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# ── MongoDB container name (untuk restore-db.sh) ─────
MONGO_CONTAINER_NAME=fp_mongo_multivm
